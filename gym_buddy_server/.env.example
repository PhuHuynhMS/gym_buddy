# Example only. The server does not auto-load this file.
# Set these values as machine/session environment variables before starting.
MONGO_URI=mongodb://127.0.0.1:27017/gym_buddy
PORT=5000
HOST=0.0.0.0
JWT_SECRET_KEY=replace-with-a-long-random-secret
NODE_ENV=development

# Local Android device testing for Secure refresh cookies.
# Create a dev certificate whose SAN contains your LAN IP/domain.
HTTPS_ENABLED=false

# Option A: Windows-friendly PFX generated by scripts/create-dev-cert.ps1.
HTTPS_PFX_PATH=certs/server.pfx
HTTPS_PFX_PASSPHRASE=gymbuddy-dev

# Option B: PEM key/cert, if you generate them with OpenSSL or another tool.
HTTPS_KEY_PATH=certs/server.key
HTTPS_CERT_PATH=certs/server.crt
